{   
    "name": "Basic Dev Environmet",
    "image": "mcr.microsoft.com/devcontainers/base:debian",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "installTools": true,
            "version": "3.10"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.debugpy",
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "bash .devcontainer/postCreate.sh"
}